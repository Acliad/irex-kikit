(version 1)
(rule Body_To_Body_Top
	(severity error)
	(constraint physical_clearance (min 0.2mm))
	(layer "F.Fab")
	(condition "A.Type != 'Text' && B.Type != 'Text' && A.Parent != B.Parent")
)
(rule Body_To_Body_Bottom 
	(severity error)
	(constraint physical_clearance (min 0.2mm))
	(layer "B.Fab")
	(condition "A.Type != 'Text' && B.Type != 'Text' && A.Parent != B.Parent")
)